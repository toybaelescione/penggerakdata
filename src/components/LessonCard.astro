---
import Tag from './Tag.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lesson: CollectionEntry<'belajar'>;
  base:   string;
}

const { lesson, base } = Astro.props;
const { title, description, domain, difficulty, companies, readingTime } = lesson.data;

const difficultyColor: Record<string, string> = {
  pemula:   'text-ac-teal',
  menengah: 'text-ac-yellow',
  mahir:    'text-ac-orange',
};
---

<a
  href={`${base}/belajar/${lesson.slug}`}
  data-domain={domain}
  class="group block bg-bg-surface border border-border-dim hover:border-ac-blue/50 rounded-md p-6 transition-all duration-200 hover:-translate-y-0.5"
>
  <div class="flex items-center justify-between mb-3">
    <Tag domain={domain} />
    <span class={`font-mono text-xs ${difficultyColor[difficulty] ?? 'text-tx-muted'}`}>
      {difficulty}
    </span>
  </div>

  <h3 class="font-sans font-semibold text-tx-primary group-hover:text-ac-blue transition-colors mb-2 leading-snug">
    {title}
  </h3>
  <p class="text-tx-muted text-sm leading-relaxed line-clamp-2">{description}</p>

  <div class="flex items-center justify-between mt-5 pt-4 border-t border-border-dim">
    <div class="flex flex-wrap gap-1.5">
      {companies.map((c: string) => (
        <span class="font-mono text-xs text-tx-muted bg-bg-elevated rounded px-2 py-0.5">{c}</span>
      ))}
    </div>
    <span class="font-mono text-xs text-tx-muted shrink-0 ml-2">~{readingTime}m</span>
  </div>
</a>
